# Airtable Personal Access Token
# Create at: https://airtable.com/create/tokens
# Grant scopes: data.records:read, data.records:write, schema.bases:read

AIRTABLE_ACCESS_TOKEN=patXXXXXXXXXXXXXX.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Default base ID (find in the Airtable URL: https://airtable.com/appXXXXXXXXXXXXXX/...)
# Individual tool calls can override this with the base_id parameter.
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
