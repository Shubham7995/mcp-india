# Zoho CRM OAuth2 credentials
# Create a Self Client at: https://api-console.zoho.com/
# Generate a refresh token with the scopes listed in the package README.

ZOHO_CLIENT_ID=1000.XXXXXXXXXXXXXXXXXXXXXXXXXXXX
ZOHO_CLIENT_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
ZOHO_REFRESH_TOKEN=1000.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Optional: override for non-US data centers
# India:  ZOHO_ACCOUNTS_URL=https://accounts.zoho.in   ZOHO_API_URL=https://www.zohoapis.in
# EU:     ZOHO_ACCOUNTS_URL=https://accounts.zoho.eu   ZOHO_API_URL=https://www.zohoapis.eu
# ZOHO_ACCOUNTS_URL=
# ZOHO_API_URL=
